{
  "permissions": {
    "allow": [
      "Bash(awk *)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(find *)",
      "Bash(git blame*)",
      "Bash(git branch*)",
      "Bash(git cat-file*)",
      "Bash(git describe*)",
      "Bash(git diff*)",
      "Bash(git grep*)",
      "Bash(git log*)",
      "Bash(git ls-files*)",
      "Bash(git ls-remote*)",
      "Bash(git remote*)",
      "Bash(git rev-parse*)",
      "Bash(git shortlog*)",
      "Bash(git show*)",
      "Bash(git stash list*)",
      "Bash(git status*)",
      "Bash(git tag*)",
      "Bash(git -C * blame*)",
      "Bash(git -C * branch*)",
      "Bash(git -C * cat-file*)",
      "Bash(git -C * describe*)",
      "Bash(git -C * diff*)",
      "Bash(git -C * grep*)",
      "Bash(git -C * log*)",
      "Bash(git -C * ls-files*)",
      "Bash(git -C * ls-remote*)",
      "Bash(git -C * remote*)",
      "Bash(git -C * rev-parse*)",
      "Bash(git -C * shortlog*)",
      "Bash(git -C * show*)",
      "Bash(git -C * stash list*)",
      "Bash(git -C * status*)",
      "Bash(git -C * tag*)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(jq *)",
      "Bash(ls *)",
      "Bash(printf *)",
      "Bash(sed -n *)",
      "Bash(sort *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "EnterPlanMode",
      "EnterWorktree",
      "ExitPlanMode",
      "ExitWorktree",
      "TaskCreate",
      "TaskGet",
      "TaskList",
      "TaskOutput",
      "TaskStop",
      "TaskUpdate",
      "mcp__pencil"
    ]
  },
  "model": "sonnet",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/alex/.claude/hooks/check-destructive-bash.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/alex/.claude/hooks/check-sensitive-write.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/alex/.claude/hooks/check-sensitive-read.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/alex/.claude/hooks/scripts/architecture-remind.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "agent",
            "prompt": "Tool context: $ARGUMENTS\n\nIf the Bash command above does NOT contain 'git commit', stop immediately and output nothing.\n\nOtherwise: run `git show --name-only --format='' HEAD` to list the files changed in the commit. Review test coverage for those files — identify missing unit tests, uncovered edge cases, and integration test gaps. Report findings concisely.",
            "timeout": 120,
            "model": "sonnet",
            "statusMessage": "Post-commit: reviewing test coverage..."
          },
          {
            "type": "agent",
            "prompt": "Tool context: $ARGUMENTS\n\nIf the Bash command above does NOT contain 'git commit', stop immediately and output nothing.\n\nOtherwise: run `git show --name-only --format='' HEAD` to list the files changed in the commit. Review those files for refactoring opportunities — long functions, duplicated logic, unclear naming, deep nesting, poor abstractions. Suggest specific actionable improvements without changing behavior.",
            "timeout": 120,
            "model": "sonnet",
            "statusMessage": "Post-commit: analyzing refactoring opportunities..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"/Users/alex/.claude/hooks/context-mode-cache-heal.mjs\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /Users/alex/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "feature-dev@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "atlassian@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "kotlin-lsp@claude-plugins-official": false,
    "claude-md-management@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "railway@claude-plugins-official": true,
    "example-skills@anthropic-agent-skills": true,
    "ecc@ecc": false,
    "swift-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "ecc": {
      "source": {
        "source": "git",
        "url": "https://github.com/affaan-m/ECC.git"
      }
    },
    "context-mode": {
      "source": {
        "source": "github",
        "repo": "mksglu/context-mode"
      }
    },
    "thedotmack": {
      "source": {
        "source": "github",
        "repo": "thedotmack/claude-mem"
      }
    }
  },
  "effortLevel": "medium",
  "skipWorkflowUsageWarning": true,
  "agentPushNotifEnabled": true
}
